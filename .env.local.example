# Copy this file to .env.local and customize.

# Admin credentials (REQUIRED — set these before first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secret-password-here

# 32+ char secret for signing JWT session cookies
AUTH_SECRET=replace-with-a-very-long-random-string-min-32-chars-please

# SQLite database file (relative to project root)
DATABASE_FILE=./data/aerotrack.sqlite
